{% extends 'back_office/base.html.twig' %}

{% block title %}Admin - Equipement{% endblock %}
{% block page_title %}Equipement{% endblock %}

{% block header_actions %}
    <a href="{{ path('back_equipement_new') }}" class="btn btn-primary btn-sm">
        <i class="lucide-plus" style="font-size:14px"></i> Ajouter equipement
    </a>
{% endblock %}

{% block body %}
    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-card-label">Articles total</div>
                <div class="stat-card-value">156</div>
                <div class="stat-card-sub">12 categories</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-card-label">En stock</div>
                <div class="stat-card-value">142</div>
                <div class="stat-card-sub">91% disponible</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-card-label">Stock bas</div>
                <div class="stat-card-value">8</div>
                <div class="stat-card-sub" style="color:#dc2626">A commander</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-card-label">Valeur inventaire</div>
                <div class="stat-card-value">45K DT</div>
                <div class="stat-card-sub">Estimation totale</div>
            </div>
        </div>
    </div>

    <div class="data-table">
        <div class="data-table-header">
            <h3>Inventaire equipement</h3>
        </div>
        <table>
            <thead>
                <tr>
                    <th>Article</th>
                    <th>Categorie</th>
                    <th>Quantite</th>
                    <th>Etat</th>
                    <th>Derniere MAJ</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for product in products %}
                    <tr>
                        <td>{{ product.name }}</td>
                        <td>{{ product.category }}</td>
                        <td>{{ product.stock }}</td>
                        <td>
                            {% if product.stock > 5 %}
                                <span class="badge-success">En stock</span>
                            {% elseif product.stock > 0 %}
                                <span class="badge-warning">Stock bas</span>
                            {% else %}
                                <span class="badge-danger">Rupture</span>
                            {% endif %}
                        </td>
                        <td>-</td>
                        <td>
                            <a href="{{ path('back_equipement_edit', { id: product.id }) }}" class="btn btn-sm btn-outline-secondary">Modifier</a>
                            <form method="POST" action="{{ path('back_equipement_delete', { id: product.id }) }}" style="display:inline;" onsubmit="return confirm('Êtes-vous sûr ?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ product.id) }}">
                                <button type="submit" class="btn btn-sm btn-outline-danger">Supprimer</button>
                            </form>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="6">Aucun produit.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
