{% extends 'back_office/base.html.twig' %}

{% block title %}Modifier equipement{% endblock %}
{% block page_title %}Modifier produit{% endblock %}

{% block body %}
    <div class="card">
        <div class="card-body">
            {{ form_start(form) }}
            {{ form_row(form.name) }}
            {{ form_row(form.category) }}
            {{ form_row(form.price) }}
            {{ form_row(form.stock) }}
            {{ form_row(form.size) }}
            {{ form_row(form.brand) }}
            {{ form_row(form.image) }}
            <div class="mt-3">
                <button class="btn btn-primary">Enregistrer</button>
                <a href="{{ path('back_equipement_index') }}" class="btn btn-secondary">Annuler</a>
            </div>
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}
