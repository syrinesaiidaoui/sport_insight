{% extends 'front_office/base.html.twig' %}

{% block title %}Mes Commandes{% endblock %}
{% block page_title %}Mes Commandes{% endblock %}

{% block body %}
    <div class="container">
        <div class="card">
            <div class="card-body">
                {% if orders|length > 0 %}
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Produit</th>
                                <th>Quantité</th>
                                <th>Date</th>
                                <th>Statut</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for order in orders %}
                                <tr>
                                    <td>{{ order.product.name }}</td>
                                    <td>{{ order.quantity }}</td>
                                    <td>{{ order.orderDate|date('d/m/Y') }}</td>
                                    <td>
                                        {% if order.status == 'pending' %}
                                            <span class="badge badge-warning">En attente</span>
                                        {% elseif order.status == 'confirmed' %}
                                            <span class="badge badge-success">Confirmée</span>
                                        {% elseif order.status == 'cancelled' %}
                                            <span class="badge badge-danger">Annulée</span>
                                        {% else %}
                                            <span class="badge badge-secondary">{{ order.status }}</span>
                                        {% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                {% else %}
                    <div class="alert alert-info">
                        Vous n'avez aucune commande. <a href="{{ path('front_equipement_index') }}">Continuer les achats</a>
                    </div>
                {% endif %}
            </div>
        </div>
        <div class="mt-3">
            <a href="{{ path('front_equipement_index') }}" class="btn btn-secondary">Retour aux équipements</a>
        </div>
    </div>
{% endblock %}
